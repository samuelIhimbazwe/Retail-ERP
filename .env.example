# Local SQLite (default)
DATABASE_URL="file:./dev.db"

# Production PostgreSQL example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rbiap?sslmode=require"

# Required for Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public app URL used in invite / reset links
# AUTH_URL="http://localhost:3000"

# Optional SMTP — when set, invites and password resets are emailed
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="RBIAP <noreply@yourbusiness.com>"
