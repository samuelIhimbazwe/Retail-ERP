# ── Shared ──────────────────────────────────────────────
# Same secret on Neon-linked API (Render) and Web (Vercel)
AUTH_SECRET="change-me-to-a-long-random-string"

# ── Neon PostgreSQL (Render API only — not required on Vercel web) ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ── Local monolith (optional: leave API_URL empty to run DB in Next.js) ──
AUTH_URL="http://localhost:3000"

# ── Split deploy (production) ───────────────────────────
# Render API:
#   DATABASE_URL=...
#   AUTH_SECRET=...
#   WEB_ORIGIN=https://your-app.vercel.app
#   PORT=4000
#
# Vercel Web:
#   API_URL=https://rbiap-api.onrender.com
#   NEXT_PUBLIC_API_URL=https://rbiap-api.onrender.com
#   AUTH_SECRET=...   (must match Render)
#   AUTH_URL=https://your-app.vercel.app
#
# Local split testing:
#   Terminal 1: npm run dev:api   (PORT=4000, DATABASE_URL=Neon)
#   Terminal 2: API_URL=http://localhost:4000 NEXT_PUBLIC_API_URL=http://localhost:4000 npm run dev

# Optional SMTP (Render API)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="RBIAP <noreply@yourbusiness.com>"
