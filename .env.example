# Local SQLite (default for development)
DATABASE_URL="file:./dev.db"

# Production PostgreSQL (required on Vercel / Railway / Render — SQLite will not persist)
# Use the pooled connection string when your host provides one (Neon / Supabase / Prisma Postgres).
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rbiap?sslmode=require"

# Required for Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public app URL (invite / reset links + Auth.js). Set this to your production domain when deploying.
# AUTH_URL="http://localhost:3000"
# AUTH_URL="https://your-app.vercel.app"

# Optional SMTP — when set, invites and password resets are emailed
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="RBIAP <noreply@yourbusiness.com>"
