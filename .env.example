# Neon PostgreSQL (required for local + production)
# Dashboard → Connection details → use the pooled URL when available (-pooler host).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Required for Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public app URL (invite / reset links + Auth.js)
# Local:
AUTH_URL="http://localhost:3000"
# Vercel example:
# AUTH_URL="https://your-app.vercel.app"
# Render example:
# AUTH_URL="https://rbiap.onrender.com"

# Optional SMTP — when set, invites and password resets are emailed
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="RBIAP <noreply@yourbusiness.com>"
